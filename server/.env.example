OPENAI_API_KEY=sk-...
OPENAI_BASE=https://api.openai.com/v1/responses
OPENAI_AUDIO_BASE=https://api.openai.com/v1/audio/transcriptions
PORT=8787

# Transcription provider
TRANSCRIBE_PROVIDER=doubao

# Doubao ASR (default transcription provider)
DOUBAO_ASR_URL=
# Newer Volcengine/Doubao console credentials. Prefer this when available.
DOUBAO_API_KEY=
# Legacy credentials. Used when DOUBAO_API_KEY is empty.
DOUBAO_APP_ID=
DOUBAO_ACCESS_TOKEN=
DOUBAO_RESOURCE_ID=volc.bigasr.auc_turbo
DOUBAO_MODEL_NAME=bigmodel
DOUBAO_USER_ID=life-narrator

# Models
MODEL_QUICK=gpt-4o-mini
MODEL_ASSIST=gpt-4o-mini
MODEL_DEEP=gpt-4o-mini

# Protection
ALLOWED_TOKENS=review-token-1,review-token-2
RATE_LIMIT_RPM=30

# Feedback
FEEDBACK_STORE_PATH=
FEEDBACK_MAX_BYTES=5000000

# Usage storage and quota tiers
USAGE_STORE_PATH=
USAGE_DEFAULT_TIER=free
USAGE_TRIAL_DAYS=7
USAGE_DAILY_USER_IDS=
USAGE_DEEP_USER_IDS=
USAGE_REVIEWER_USER_IDS=
USAGE_TIER_OVERRIDES={}
USAGE_CREDIT_LIMIT_OVERRIDES={}
USAGE_CREDIT_COST_OVERRIDES={}
